public class CalculoNominasFinal {

    // Se declaran fuera del main 
    // 5. USO DE CONSTANTES (final double)
    private static final double PAGO_HORA_JUNIOR = 10.0; // Precio hora categoría Junior
    private static final double PAGO_HORA_SENIOR = 20.0; // Precio hora categoría Senior
    private static final double PORCENTAJE_RETENCION = 0.15; // Declaramos el porcentaje de retención
    private static final double COMISION_ALTA = 0.10; // Comisión para un tipo de ventas superiores al resto
    private static final double COMISION_BAJA = 0.05; // Comisión mínima para un tipo de ventas normales
    private static final double LIMITE_VENTAS_COMISION = 1000.0; // Es el límite de ventas para tener una comisión alta

    public static void main(String[] args) {
        // 3. RENOMBRADO (Nombres significativos)
        String[] nombresEmpleados = {"Ana", "Juan", "Elena"};
        int[] horasTrabajadas = {160, 180, 140};
        int[] categorias = {1, 2, 1}; // 1: Junior, 2: Senior
        double[] ventasRealizadas = {500.0, 2000.0, 0.0};

        double costeTotalEmpresa = 0;

        for (int i = 0; i < nombresEmpleados.length; i++) {
            // 4. MÉTODOS EXTRAÍDOS
            double sueldoBase = calcularBruto(horasTrabajadas[i], categorias[i]);
            double comision = calcularComision(ventasRealizadas[i]);

            double sueldoBrutoTotal = sueldoBase + comision;
            double retencion = sueldoBrutoTotal * PORCENTAJE_RETENCION;
            double sueldoNeto = sueldoBrutoTotal - retencion;

            System.out.println("--------------------------------------------");
            System.out.println("         --- E M P L E A D O ---  ");
            System.out.println("--------------------------------------------");

            System.out.println("EMPLEADO: " + nombresEmpleados[i] + " || Sueldo Neto: " + sueldoNeto + " Euros ");

            costeTotalEmpresa += sueldoNeto;
        }

        System.out.println("-------------------------------------------");
        System.out.println("    --- C O S T E    T O T A L ---");
        System.out.println("-------------------------------------------");
        System.out.println("Coste total para la empresa: " + costeTotalEmpresa + " Euros ");
    }

    // --- MÉTODOS EXTRAÍDOS ---
    // Calcula el sueldo bruto base según las horas y la categoría.
    public static double calcularBruto(int horas, int categoria) {
        if (categoria == 1) {
            return horas * PAGO_HORA_JUNIOR;
        } else if (categoria == 2) {
            return horas * PAGO_HORA_SENIOR;
        }
        return 0;
    }

    // Calcula la comisión basada en el volumen de ventas.
    public static double calcularComision(double ventas) {
        if (ventas > LIMITE_VENTAS_COMISION) {
            return ventas * COMISION_ALTA;
        } else {
            return ventas * COMISION_BAJA;
        }
    }
}

