public static void main(String[] args) {

        //EN ESTE COMMIT SOLO HEMOS CUMPLIDO EL OBJETIVO DE CAMBIAR LAS VARIABLES PARA QUE SEAN MÁS DESCRIPTIVAS
        // --- Configuración de datos de los empleados ---
        String[] nombresEmpleados = {"Ana", "Juan", "Elena"};
        int[] horasTrabajadas = {160, 180, 140};
        int[] categorias = {1, 2, 1}; // Define el pago por hora según la categoria
        double[] ventasRealizadas = {500.0, 2000.0, 0.0};
        double costeTotalEmpresa = 0; // Acumulador para el gasto total en salarios brutos

        // --- Proceso de cálculo de nóminas ---
        for (int i = 0; i < nombresEmpleados.length; i++) {
            double salarioBruto = 0;

            // 1. Cálculo del sueldo base según la categoría del trabajador
            if (categorias[i] == 1) {
                // Multiplicamos las horas por la tarifa de la categoría 1
                salarioBruto = horasTrabajadas[i] * 10;
            } else if (categorias[i] == 2) {
                // Multiplicamos las horas por la tarifa de la categoría 2
                salarioBruto = horasTrabajadas[i] * 20;
            }

            // 2. Cálculo del incentivo por comisión
            if (ventasRealizadas[i] > 1000) {
                // Aplicamos un 10% si las ventas superan los 1000 euros 
                salarioBruto += (ventasRealizadas[i] * 0.10);
            } else {
                // Aplicamos un 5% para ventas iguales o inferiores a 1000 eruos 
                salarioBruto += (ventasRealizadas[i] * 0.05);
            }

            // 3. Aplicación el 15% de retenciones IRPF 
            double retencionIrpf = salarioBruto * 0.15;
            double sueldoNeto = salarioBruto - retencionIrpf; // Sueldo líquido a percibir

            // --- Salida en pantalla de resultados ---
            System.out.println("EMPLEADO: " + nombresEmpleados[i] + " || Sueldo Neto: " + sueldoNeto + " Euros ");

            // Sumamos el bruto al total para obtener el coste real para la empresa
            costeTotalEmpresa += salarioBruto;
        }
        // Imprimimos en pantalla el coste total para la empresa
        System.out.println("    --- RESUMEN DE COSTES ---  ");
        System.out.println("El coste total para la empresa es de " + costeTotalEmpresa + " Euros ");
    }
}
